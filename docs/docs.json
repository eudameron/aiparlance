              "en/cost-impact"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "en/specification",
              "en/syntax"
            ]
          },
          {
            "group": "Domains",
            "pages": [
              "en/database",
              "en/security",
              "en/workflows"
            ]
          },
          {
            "group": "AI",
            "pages": [
              "en/agents"
            ]
          }
        ]
      },
      {
        "language": "pt",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "pt/introduction",
              "pt/cost-impact"
            ]
          },
          {
            "group": "Referência",
            "pages": [
              "pt/specification",
              "pt/syntax"
            ]
          },
          {
            "group": "Domínios",
            "pages": [
              "pt/database",
              "pt/security",
              "pt/workflows"
            ]
          },
          {
            "group": "IA",
            "pages": [
              "pt/agents"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "aiparlance.org",
        "href": "https://aiparlance.org"
      },
      {
        "label": "GitHub",
