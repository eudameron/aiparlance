{
  "$schema": "https://mintlify.com/docs.json",
  "name": "AI Parlance",
  "description": "AI-first intermediate representation for AI-assisted software generation.",
  "theme": "mint",
  "colors": {
    "primary": "#7C3AED",
    "light": "#22D3EE",
    "dark": "#6366F1"
  },
  "logo": {
    "light": "/logo-nav.png",
    "dark": "/logo-nav.png",
    "href": "https://docs.aiparlance.org/en/introduction"
  },
  "favicon": "/favicon.png",
  "seo": {
    "metatags": {
      "canonical": "https://docs.aiparlance.org",
      "og:url": "https://docs.aiparlance.org"
    }
  },
  "navigation": {
