---
import { defaultLocale, localePath } from "@/i18n";

const target = localePath(defaultLocale);
const canonical = new URL(target, Astro.site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="noindex" />
    <script is:inline define:vars={{ target }}>
      location.replace(target);
    </script>
  </head>
  <body>
    <p><a href={target}>Continue to {defaultLocale === "en" ? "English" : defaultLocale}</a></p>
  </body>
</html>
